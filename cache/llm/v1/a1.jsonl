{"block_hash": "a12ca9e7fdea8b3ec58265fa5afa7af9ea8378a4005c4d54f515b326ddd39286", "items": [{"item_text": "Samlegjenstander av div. pins, medaljer og klokker. Mottatt deler av samlingen som gave. Verdi av hele samlingen ca. 5 000 kroner.", "organisation": null, "role": "gave", "remuneration": null, "amount_nok": 5000, "share_count": null, "share_pct": null, "org_number": null, "date_from": null, "date_to": null, "country": null}, {"item_text": "Åpnet kunstutstillingen til Thore Sveberg den 23. juni 2019, mottatt et lite malt bilde som takk for hjelpen. Verdi ukjent.", "organisation": "Thore Sveberg", "role": "gave", "remuneration": null, "amount_nok": null, "share_count": null, "share_pct": null, "org_number": null, "date_from": "2019-06-23", "date_to": null, "country": null}, {"item_text": "Mottatt sett med treningstøy fra stiftelsen Aktiv mot kreft(nov-2019).", "organisation": "stiftelsen Aktiv mot kreft", "role": "gave", "remuneration": null, "amount_nok": null, "share_count": null, "share_pct": null, "org_number": null, "date_from": "2019-11", "date_to": null, "country": null}, {"item_text": "Har sammen med kona mi 4 andeler i en travhest (Alm Tanaka) Står på Stall Undem i Skien. Sammen med andre privatpersoner.", "organisation": "Alm Tanaka", "role": "andeler i travhest", "remuneration": null, "amount_nok": null, "share_count": 4, "share_pct": null, "org_number": null, "date_from": null, "date_to": null, "country": null}, {"item_text": "Var hos Veidekke i Skien, fikk orientering om entreprenør/asfaltbransjen. Var med på asfaltering i Skien på dagen, og på E18 i Porsgrunn på kveld, fikk beholde bekledningen/vernesko/utstyr som ble brukt under besøkene. Usikker på verdi.", "organisation": "Veidekke", "role": "besøk", "remuneration": null, "amount_nok": null, "share_count": null, "share_pct": null, "org_number": null, "date_from": null, "date_to": null, "country": null}, {"item_text": "Har gitt ut boken Slankereisen sammen med Hege Hasler Barhaughøgda. Kan gi inntekter etter salget. Men tanken er et eventuelt overskudd her skal gis bort til en organisasjon.", "organisation": "Hege Hasler Barhaughøgda", "role": "bokutgivelse", "remuneration": null, "amount_nok": null, "share_count": null, "share_pct": null, "org_number": null, "date_from": null, "date_to": null, "country": null}, {"item_text": "Mottok 12 flasker Nøgne øl med oversikt over de som har gitt ut bok i 2021.Fra Kagge forlag Desember 2021.", "organisation": "Kagge forlag", "role": "gave", "remuneration": null, "amount_nok": null, "share_count": 12, "share_pct": null, "org_number": null, "date_from": "2021-12", "date_to": null, "country": null}, {"item_text": "Har en bolig sammen med min søster, hennes mann og min kone og vi leide ut boligen i 3 uker sommeren 2021.", "organisation": null, "role": "utleie", "remuneration": null, "amount_nok": null, "share_count": null, "share_pct": null, "org_number": null, "date_from": "2021-06", "date_to": "2021-08", "country": null}, {"item_text": "Hadde beboere i deler av huset fra mars, og har mottatt husleie fra Mai 2022.", "organisation": null, "role": "husleie", "remuneration": null, "amount_nok": null, "share_count": null, "share_pct": null, "org_number": null, "date_from": "2022-03", "date_to": null, "country": null}], "model": "openai/gpt-4o-mini", "prompt_version": "v1"}
